   "source": [
    "import time\n",
    "a = np.random.rand(100000)\n",
    "b = np.random.rand(100000)\n",
    "\n",
    "tic = time.time()\n",
    "c = np.dot(a,b)\n",
    "toc =  time.time()\n",
    "\n",
    "print(str(1000*(toc-tic)) + 'ms')\n"
   ]
  },
